.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(ellipse at 20% 10%, rgba(59, 130, 246, 0.1) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 90%, rgba(244, 201, 107, 0.08) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, rgba(139, 92, 246, 0.05) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.page-header {
  text-align: center;
  padding: 40rpx 0 40rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: pulse 2s ease-in-out infinite;
}

.page-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #f8fafc;
  text-shadow: 0 0 30rpx rgba(59, 130, 246, 0.5);
}

.weapon-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.weapon-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.weapon-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.weapon-tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(59, 130, 246, 0.18);
  color: #93c5fd;
  font-size: 22rpx;
  font-weight: 600;
  width: fit-content;
}

.weapon-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
}

.weapon-right {
  display: flex;
  align-items: center;
}

.weapon-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(244, 201, 107, 0.2) 0%, rgba(234, 179, 8, 0.15) 100%);
  color: #f4c96b;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(244, 201, 107, 0.3);
}

.weapon-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
}
