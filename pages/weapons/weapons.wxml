<view class="container">
  <view class="bg-decoration"></view>
  
  <view class="page-header">
    <view class="header-icon">⚔️</view>
    <view class="page-title centered-title">武器信息</view>
  </view>

  <view class="weapon-list">
    <block wx:for="{{items}}" wx:key="title">
      <view class="weapon-card panel" data-page="{{item.page}}" bindtap="goToDetail">
        <view class="weapon-info">
          <view class="weapon-tag">{{item.tag}}</view>
          <view class="weapon-title">{{item.title}}</view>
        </view>
        <view class="weapon-right">
          <view class="weapon-link">查看详情</view>
        </view>
      </view>
    </block>
  </view>
</view>
