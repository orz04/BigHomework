page {
  background: #f2f3f5;
}

.reward-page {
  min-height: 100vh;
  background: #f2f3f5;
  color: #111;
}

.reward-header {
  height: 66rpx;
  border-bottom: 1rpx solid #b8c1d3;
  background: #d9d9d9;
  line-height: 66rpx;
  text-align: center;
}

.reward-title {
  font-size: 30rpx;
  font-weight: 700;
}

.reward-scroll {
  height: calc(100vh - 66rpx);
}

/* 整张奖励表的外层容器 */
.reward-table {
  display: flex;
  flex-direction: column;
  border-top: 1rpx solid #b8c1d3;
  border-left: 1rpx solid #b8c1d3;
  background: #f7f9fc;
}

/* 每个武器占一组，左侧武器名，右侧多行配件 */
.reward-group {
  display: flex;
  align-items: stretch;
}

.item-name {
  width: 188rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 10rpx;
  border-right: 1rpx solid #b8c1d3;
  border-bottom: 1rpx solid #b8c1d3;
  background: #fbfcff;
  color: #1e88e5;
  font-size: 24rpx;
  line-height: 1.35;
  text-align: center;
  word-break: break-all;
  flex-shrink: 0;
}

.group-body {
  flex: 1;
  min-width: 0;
}

/* 每行对应一个配件分类 */
.reward-row {
  display: flex;
  min-height: 76rpx;
}

.part-name {
  width: 110rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 6rpx;
  border-right: 1rpx solid #b8c1d3;
  border-bottom: 1rpx solid #b8c1d3;
  background: #fbfcff;
  color: #2d2d2d;
  font-size: 21rpx;
  line-height: 1.3;
  text-align: center;
  flex-shrink: 0;
}

/* 右侧遗物标签区域，允许自动换行 */
.relic-list {
  flex: 1;
  box-sizing: border-box;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx;
  border-right: 1rpx solid #b8c1d3;
  border-bottom: 1rpx solid #b8c1d3;
  background: #fbfcff;
}

/* 单个遗物标签 */
.relic-card {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  height: 28rpx;
  padding: 0 20rpx 0 10rpx;
  border: 2rpx solid #6f7073;
  border-radius: 4rpx;
  background: #7a7b7f;
  color: #fff;
  font-size: 17rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  box-shadow: inset 0 1rpx rgba(255, 255, 255, 0.18);
}

/* 右下角小色块用于区分稀有度 */
.relic-card::after {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 16rpx;
  height: 12rpx;
  border-left: 2rpx solid rgba(0, 0, 0, 0.3);
  content: '';
}

.rarity-1::after {
  background: #c8d0d1;
}

.rarity-2::after {
  background: #bf9049;
}

.rarity-3::after {
  background: #e5dd2f;
}
