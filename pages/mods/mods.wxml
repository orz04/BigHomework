<view class="container">
  <view class="page-header">
    <view class="page-title">MOD</view>
    <view class="page-desc">先展示分类框架，后续再补具体词条、数值、适用流派与推荐搭配。</view>
  </view>

  <view class="section">
    <view class="section-title">分类标签</view>
    <view class="chips">
      <block wx:for="{{filters}}" wx:key="*this">
        <view class="chip">{{item}}</view>
      </block>
    </view>
  </view>

  <view class="list section">
    <block wx:for="{{items}}" wx:key="title">
      <section-card title="{{item.title}}" desc="{{item.desc}}" tag="{{item.tag}}"></section-card>
    </block>
  </view>
</view>
