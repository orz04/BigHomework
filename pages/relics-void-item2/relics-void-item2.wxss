page {
  background: #f2f3f5;
}

.page {
  min-height: 100vh;
  background: #f2f3f5;
  color: #111;
}

.header {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 64rpx;
  border-bottom: 1rpx solid #b8c1d3;
  background: #d9d9d9;
  position: relative;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
}

.collapse {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #111;
}

.table {
  border-top: 1rpx solid #b8c1d3;
}

.row {
  display: flex;
  border-bottom: 1rpx solid #b8c1d3;
}

.label {
  width: 188rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  background: #ddd;
  border-right: 1rpx solid #b8c1d3;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.chips-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 12rpx 12rpx 10rpx;
  background: #f7f7f7;
}

.chips-wrap-grouped {
  flex-direction: column;
}

.chip-line {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

.chip {
  height: 36rpx;
  padding: 0 16rpx;
  border-radius: 8rpx;
  border: 2rpx solid #545454;
  background: #545454;
  color: #fff;
  font-size: 22rpx;
  line-height: 32rpx;
  box-shadow: inset 0 1rpx rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}
.chip-active {
  border-color: #2f6bff;
  background: #f7fbff;
  color: #2f6bff;
}


.data-table-wrap {
  margin-top: 20rpx;
  padding: 0 12rpx 24rpx;
}

.data-table-scroll {
  width: 100%;
}

.data-table {
  width: max-content;
  min-width: 1200rpx;
  margin: 0 auto;
  border-top: 1rpx solid #b8c1d3;
  border-left: 1rpx solid #b8c1d3;
  background: #f7f7f7;
}

.data-table-row {
  display: grid;
  grid-template-columns: 220rpx 180rpx 180rpx 180rpx 440rpx;
  border-bottom: 1rpx solid #b8c1d3;
}

.data-table-head {
  background: #d9d9d9;
}

.data-table-cell {
  box-sizing: border-box;
  min-height: 76rpx;
  padding: 18rpx 16rpx;
  border-right: 1rpx solid #b8c1d3;
  color: #333;
  font-size: 24rpx;
  line-height: 1.4;
  word-break: break-word;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #f7f7f7;
}

.data-table-cell:last-child {
  border-right: 0;
}

.data-table-head-cell {
  color: #111;
  font-weight: 700;
  background: #d9d9d9;
}

.data-table-cell-sticky {
  position: sticky;
  left: 0;
  z-index: 2;
  background: #f7f7f7;
}

.data-table-head .data-table-cell-sticky {
  z-index: 3;
  background: #d9d9d9;
}

.data-table-body-row {
  border-bottom: 1rpx solid #b8c1d3;
}

.data-table-body-row:last-child {
  border-bottom: 0;
}

.data-table-empty {
  color: #666;
}
