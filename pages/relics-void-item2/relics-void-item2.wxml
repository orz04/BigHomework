<view class="page">
  <view class="header">
    <view class="title">内容筛选</view>
    <view class="collapse" bindtap="handleCollapseToggle">[{{collapsed ? '展开' : '折叠'}}]</view>
  </view>

  <view class="table" wx:if="{{!collapsed}}">
    <block wx:for="{{sections}}" wx:key="title" wx:for-item="section" wx:for-index="sectionIndex">
      <view class="row">
        <view class="label">{{section.title}}</view>
        <view class="chips-wrap {{section.groups ? 'chips-wrap-grouped' : ''}}">
          <block wx:if="{{section.groups}}">
            <block wx:for="{{section.groups}}" wx:key="index" wx:for-item="group">
              <view class="chip-line">
                <block wx:for="{{group}}" wx:key="chipIndex" wx:for-item="chip">
                  <view
                    class="chip {{section.activeChipIndex === chip.chipIndex ? 'chip-active' : ''}}"
                    data-section-index="{{sectionIndex}}"
                    data-chip-index="{{chip.chipIndex}}"
                    bindtap="handleChipSelect"
                  >
                    {{chip.label}}
                  </view>
                </block>
              </view>
            </block>
          </block>
          <block wx:else>
            <block wx:for="{{section.chips}}" wx:key="*this" wx:for-index="chipIndex">
              <view
                class="chip {{section.activeChipIndex === chipIndex ? 'chip-active' : ''}}"
                data-section-index="{{sectionIndex}}"
                data-chip-index="{{chipIndex}}"
                bindtap="handleChipSelect"
              >
                {{item}}
              </view>
            </block>
          </block>
        </view>
      </view>
    </block>
  </view>

  <view class="data-table-wrap">
    <scroll-view class="data-table-scroll" scroll-x>
      <view class="data-table">
        <view class="data-table-row data-table-head">
          <view class="data-table-cell data-table-head-cell data-table-cell-sticky">{{tableHeaders[0]}}</view>
          <block wx:for="{{tableHeaders}}" wx:key="*this">
            <view class="data-table-cell data-table-head-cell" wx:if="{{index > 0}}">{{item}}</view>
          </block>
        </view>
        <block wx:if="{{visibleRows.length}}">
          <block wx:for="{{visibleRows}}" wx:key="index" wx:for-item="row">
            <view class="data-table-row">
              <view class="data-table-cell data-table-cell-sticky">{{row.relicName}}</view>
              <view class="data-table-cell">{{row.region}}</view>
              <view class="data-table-cell">{{row.missionType}}</view>
              <view class="data-table-cell">{{row.node}}</view>
              <view class="data-table-cell">{{row.dropInfo}}</view>
            </view>
          </block>
        </block>
        <view class="data-table-row" wx:else>
          <view class="data-table-cell data-table-empty">暂无数据</view>
          <view class="data-table-cell data-table-empty"></view>
          <view class="data-table-cell data-table-empty"></view>
          <view class="data-table-cell data-table-empty"></view>
          <view class="data-table-cell data-table-empty"></view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>