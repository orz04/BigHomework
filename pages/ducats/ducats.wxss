page {
  background: #11171d;
}

.ducats-page {
  min-height: 100vh;
  background: #11171d;
  color: #e6edf3;
}

.hero {
  position: relative;
  height: 172rpx;
  background: linear-gradient(180deg, #10181f 0%, #121b22 100%);
  overflow: hidden;
}

.hero::after {
  position: absolute;
  top: -10rpx;
  right: -40rpx;
  width: 280rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(89, 132, 118, 0.18) 0%, rgba(89, 132, 118, 0) 72%);
  content: '';
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(8, 13, 17, 0.9) 0%, rgba(8, 13, 17, 0.58) 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  height: 100%;
  padding: 0 26rpx;
  box-sizing: border-box;
}

.hero-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  color: #f4f7fb;
  font-size: 38rpx;
  font-weight: 700;
}

.hero-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f3f6f9;
  letter-spacing: 1rpx;
}

.content-panel {
  padding: 22rpx 0 0;
}

.faq-search-row {
  display: flex;
  justify-content: space-between;
  gap: 26rpx;
  padding: 0 26rpx 22rpx;
}

.search-block {
  width: 260rpx;
  flex-shrink: 0;
  padding-top: 0;
}

.search-label {
  margin-bottom: 16rpx;
  color: #d9e0e5;
  font-size: 26rpx;
  font-weight: 700;
}

.search-input {
  height: 60rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.9);
  border-radius: 10rpx;
  background: #151515;
  color: #f5f7fa;
  box-sizing: border-box;
}

.table-shell {
  display: block;
  width: auto;
  margin: 0 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 18rpx;
  overflow: hidden;
  background: #182127;
  max-height: calc(100vh - 300rpx);
}

.table-row {
  display: flex;
  align-items: stretch;
  min-width: 0;
}

.table-fixed-header,
.table-fixed-cell,
.table-cell {
  min-height: 92rpx;
  padding: 18rpx;
  box-sizing: border-box;
}

.table-fixed-header,
.table-fixed-cell {
  width: 380rpx;
  flex-shrink: 0;
  border-right: 1rpx solid rgba(255, 255, 255, 0.06);
}

.table-fixed-header {
  display: flex;
  align-items: center;
  background: #151d23;
  color: #d8dfe5;
  font-size: 22rpx;
  font-weight: 700;
}

.table-fixed-cell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #f4f7fb;
  font-size: 22rpx;
  background: #19222a;
}

.item-name-cell {
  align-items: center;
}

.item-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.item-icon-placeholder {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.item-name-text {
  flex: 1;
  min-width: 0;
}

.empty-row {
  display: flex;
}

.empty-fixed-cell {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 92rpx;
  padding: 18rpx;
  color: #9aa7b2;
  font-size: 24rpx;
  box-sizing: border-box;
}

.table-header-row {
  background: #151d23;
}

.table-body-row {
  background: #1b242b;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.table-body-row:nth-child(even) {
  background: #1e2830;
}

.table-cell {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  color: #d4dbe1;
  font-size: 22rpx;
}

.table-head-cell {
  color: #d8dfe5;
  font-weight: 700;
}

.ducats-cell {
  justify-content: space-between;
  gap: 16rpx;
  color: #f0d27b;
}

.add-header-spacer {
  width: 72rpx;
  flex-shrink: 0;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: #24303a;
  color: #e6edf3;
  font-size: 20rpx;
  flex-shrink: 0;
}

.floating-launcher {
  position: fixed;
  left: 18rpx;
  top: 50%;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  margin-top: -34rpx;
  border-radius: 999rpx;
  background: rgba(24, 33, 39, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: #f0d27b;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.35);
}

.floating-launcher-text {
  font-size: 26rpx;
  font-weight: 700;
}

.popup-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  background: rgba(0, 0, 0, 0.42);
}

.popup-panel {
  position: fixed;
  left: 50%;
  top: 50%;
  z-index: 41;
  width: 650rpx;
  max-width: calc(100vw - 32rpx);
  max-height: 78vh;
  transform: translate(-50%, -50%);
  border-radius: 20rpx;
  background: #182127;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.45);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.popup-title {
  color: #f3f6f9;
  font-size: 28rpx;
  font-weight: 700;
}

.popup-close {
  color: #9aa7b2;
  font-size: 36rpx;
  line-height: 1;
}

.popup-list {
  flex: 1;
  min-height: 0;
  padding: 14rpx 16rpx 0;
}

.popup-item {
  display: flex;
  gap: 14rpx;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.popup-item-icon {
  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
}

.popup-item-icon-placeholder {
  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
}

.popup-item-main {
  flex: 1;
  min-width: 0;
}

.popup-item-top,
.popup-item-bottom {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.popup-item-top {
  justify-content: flex-start;
  margin-bottom: 12rpx;
}

.popup-item-bottom {
  justify-content: space-between;
}

.popup-item-price-block {
  min-width: 120rpx;
}

.popup-item-label {
  display: block;
  margin-bottom: 4rpx;
  color: #9aa7b2;
  font-size: 18rpx;
}

.popup-item-total-block {
  text-align: right;
}

.popup-item-name {
  flex: 1;
  min-width: 0;
  color: #f4f7fb;
  font-size: 22rpx;
}

.popup-item-price,
.popup-item-subtotal,
.popup-total-value {
  color: #f0d27b;
  font-size: 24rpx;
  font-weight: 700;
}

.popup-stepper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.popup-stepper-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: #24303a;
  color: #f4f7fb;
  font-size: 26rpx;
}

.popup-stepper-count {
  min-width: 36rpx;
  text-align: center;
  color: #d8dfe5;
  font-size: 22rpx;
}

.popup-empty {
  padding: 42rpx 24rpx;
  color: #9aa7b2;
  font-size: 24rpx;
  text-align: center;
}

.popup-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx 22rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  background: #151d23;
}

.popup-total-label {
  color: #d8dfe5;
  font-size: 24rpx;
  font-weight: 700;
}
