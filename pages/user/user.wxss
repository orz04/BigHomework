.user-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 28rpx 32rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(244, 201, 107, 0.22), transparent 34%),
    linear-gradient(160deg, rgba(15, 23, 42, 0.98) 0%, rgba(8, 16, 29, 0.96) 100%);
}

.hero-title {
  position: relative;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
  color: #f8fafc;
}

/* ===== 未登录：登录卡片 ===== */
.login-card {
  margin-top: 24rpx;
  padding: 32rpx 28rpx 36rpx;
}

.login-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.login-mark {
  color: rgba(244, 201, 107, 0.52);
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1;
}

.login-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.avatar-wrap {
  margin: 36rpx auto 24rpx;
  display: flex;
  justify-content: center;
}

.avatar-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-button::after {
  display: none;
}

.avatar-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(244, 201, 107, 0.6);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.35);
  background: rgba(15, 23, 42, 0.65);
}

.avatar-hint {
  font-size: 22rpx;
  color: #94a3b8;
}

.form-row {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.65);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.form-label {
  font-size: 26rpx;
  color: #cbd5e1;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  height: 56rpx;
  color: #f8fafc;
  font-size: 28rpx;
}

.form-placeholder {
  color: #64748b;
}

.primary-button {
  margin-top: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f4c96b 0%, #c7921c 100%);
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.primary-button::after {
  display: none;
}

.primary-button--disabled {
  opacity: 0.7;
}

/* ===== 已登录：头像 + 昵称 ===== */
.profile-block {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.profile-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(244, 201, 107, 0.7);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.45);
  background: rgba(15, 23, 42, 0.6);
}

.profile-nickname {
  margin-top: 4rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 1rpx;
}

.profile-id {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.65);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  font-size: 22rpx;
  color: #94a3b8;
  font-family: "SFMono-Regular", Consolas, "Microsoft YaHei", monospace;
}

.profile-id__copy {
  color: #f4c96b;
  font-family: "PingFang SC", sans-serif;
}

/* ===== 入口卡片：我的收藏 / 浏览历史 ===== */
.entry-card {
  margin-top: 28rpx;
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
}

.entry-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
}

.entry-link {
  font-size: 22rpx;
  color: #94a3b8;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 4rpx 6rpx 16rpx;
}

.entry-link__arrow {
  font-size: 26rpx;
  line-height: 1;
  color: #94a3b8;
}

.entry-empty {
  margin-top: 24rpx;
  padding: 36rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.55);
  border: 1rpx dashed rgba(148, 163, 184, 0.18);
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
}

.entry-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.entry-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.entry-item__title {
  flex: 1;
  font-size: 26rpx;
  color: #e2e8f0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-item__tag {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(244, 201, 107, 0.16);
  color: #f4c96b;
  font-size: 20rpx;
}

.entry-item__time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #64748b;
}

/* ===== 退出登录 ===== */
.logout-wrap {
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-button {
  width: 320rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  background: rgba(127, 29, 29, 0.18);
  color: #fca5a5;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(252, 165, 165, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-button::after {
  display: none;
}

/* ===== 状态条 ===== */
.status {
  margin-top: 22rpx;
  padding: 16rpx 22rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  background: rgba(30, 41, 59, 0.7);
  color: #cbd5e1;
  border-left: 4rpx solid rgba(148, 163, 184, 0.5);
}

.status--success {
  color: #86efac;
  border-left-color: #22c55e;
  background: rgba(22, 101, 52, 0.25);
}

.status--warn {
  color: #fcd34d;
  border-left-color: #f59e0b;
  background: rgba(120, 53, 15, 0.2);
}

.status--error {
  color: #fca5a5;
  border-left-color: #ef4444;
  background: rgba(127, 29, 29, 0.2);
}

.status--info {
  color: #cbd5e1;
  border-left-color: #64748b;
}
