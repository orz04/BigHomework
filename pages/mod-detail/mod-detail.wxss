.mod-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
}

.mod-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 20rpx;
}

.mod-image {
  width: 400rpx;
  height: 400rpx;
}

.info-card {
  padding: 0;
  overflow: hidden;
}

.card-title {
  background: rgba(59, 130, 246, 0.12);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #e2e8f0;
  text-align: center;
}

.info-table {
  width: 100%;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell-left {
  width: 40%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  background: #000000;
}

.table-cell-right {
  width: 60%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #d1d5db;
}

.polarity-icon {
  width: 32rpx;
  height: 32rpx;
}

.tax-icon {
  width: 32rpx;
  height: 32rpx;
}

.table-cell-right text {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.source-container {
  width: 60%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d1d5db;
}

.source-container .source-label {
  font-weight: 700 !important;
  color: #1f2937 !important;
  font-size: 26rpx;
}

.source-container .source-value {
  color: #1f2937 !important;
  font-size: 26rpx;
}

.source-container .source-rate {
  font-size: 26rpx;
  font-weight: 700 !important;
}

.source-container .source-rate-red {
  color: #dc2626 !important;
}

.source-container .source-rate-green {
  color: #16a34a !important;
}

.detail-card {
  padding: 0;
  overflow: hidden;
  margin-top: 20rpx;
}

.detail-table {
  width: 100%;
}

.detail-row {
  display: flex;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row.detail-header .detail-cell {
  background: #000000;
  color: #ffffff;
  font-weight: 700;
}

.detail-row:not(.detail-header) .detail-cell {
  background: #d1d5db;
  color: #1f2937;
  font-weight: 500;
}

.detail-cell {
  width: 25%;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
}