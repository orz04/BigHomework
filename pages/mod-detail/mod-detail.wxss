.mod-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
}

.mod-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 20rpx;
}

.mod-title-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 20rpx;
}

.mod-title-row .mod-title {
  flex: 1;
  text-align: center;
  margin-bottom: 0;
}

.favorite-btn {
  position: absolute;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.6);
  border: 2rpx solid rgba(148, 163, 184, 0.3);
  transition: transform 0.2s ease, background 0.2s ease;
}

.favorite-btn--hover {
  transform: translateY(-50%) scale(0.94);
}

.favorite-btn--active {
  background: rgba(244, 201, 107, 0.18);
  border-color: rgba(244, 201, 107, 0.7);
}

.favorite-icon {
  font-size: 44rpx;
  line-height: 44rpx;
  color: rgba(148, 163, 184, 0.95);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn--active .favorite-icon {
  color: #f4c96b;
  text-shadow: 0 0 12rpx rgba(244, 201, 107, 0.55);
}

.mod-image {
  width: 400rpx;
  height: 400rpx;
}

.info-card {
  padding: 0;
  overflow: hidden;
}

.card-title {
  background: rgba(59, 130, 246, 0.12);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #e2e8f0;
  text-align: center;
}

.info-table {
  width: 100%;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell-left {
  width: 40%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  background: #000000;
}

.table-cell-right {
  width: 60%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #d1d5db;
}

.polarity-icon {
  width: 32rpx;
  height: 32rpx;
}

.tax-icon {
  width: 32rpx;
  height: 32rpx;
}

.table-cell-right text {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.source-container {
  width: 60%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #d1d5db;
}

.source-container .source-label {
  font-weight: 700 !important;
  color: #1f2937 !important;
  font-size: 26rpx;
}

.source-container .source-value {
  color: #1f2937 !important;
  font-size: 26rpx;
}

.source-container .source-rate {
  font-size: 26rpx;
  font-weight: 700 !important;
}

.source-container .source-rate-red {
  color: #dc2626 !important;
}

.source-container .source-rate-green {
  color: #16a34a !important;
}

.detail-card {
  padding: 0;
  overflow: hidden;
  margin-top: 20rpx;
}

.detail-table {
  width: 100%;
}

.detail-row {
  display: flex;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row.detail-header .detail-cell {
  background: #000000;
  color: #ffffff;
  font-weight: 700;
}

.detail-row:not(.detail-header) .detail-cell {
  background: #d1d5db;
  color: #1f2937;
  font-weight: 500;
}

.detail-cell {
  width: 25%;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
}