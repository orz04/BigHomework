.weapon-list {
  padding: 20rpx;
}

.weapon-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  cursor: pointer;
  transition: background-color 0.3s;
}

.weapon-item:last-child {
  margin-bottom: 0;
}

.weapon-item:active {
  background-color: rgba(59, 130, 246, 0.2);
}

.weapon-image {
  width: 120rpx;
  height: 120rpx;
  margin-right: 24rpx;
  border-radius: 8rpx;
}

.weapon-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.weapon-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 8rpx;
}

.weapon-tag {
  font-size: 24rpx;
  color: #94a3b8;
}
