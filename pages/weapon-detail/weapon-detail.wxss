.weapon-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
}

.weapon-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 20rpx;
}

.weapon-title-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 20rpx;
}

.weapon-title-row .weapon-title {
  flex: 1;
  text-align: center;
  margin-bottom: 0;
}

.favorite-btn {
  position: absolute;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.6);
  border: 2rpx solid rgba(148, 163, 184, 0.3);
  transition: transform 0.2s ease, background 0.2s ease;
  line-height: 1;
  padding: 0;
}

.favorite-btn--hover {
  transform: translateY(-50%) scale(0.94);
}

.favorite-btn--active {
  background: rgba(244, 201, 107, 0.18);
  border-color: rgba(244, 201, 107, 0.7);
}

.favorite-icon {
  font-size: 42rpx;
  line-height: 1;
  color: rgba(148, 163, 184, 0.95);
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  /* 通过负 margin 抵消字符基线偏移，让视觉居中 */
  margin-top: -4rpx;
}

.favorite-btn--active .favorite-icon {
  color: #f4c96b;
  text-shadow: 0 0 12rpx rgba(244, 201, 107, 0.55);
}

.weapon-image {
  width: 400rpx;
  height: 400rpx;
}

.source-card {
  padding: 0;
  overflow: hidden;
  margin-top: 20rpx;
}

.source-content {
  padding: 20rpx 24rpx;
}

.source-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.source-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.source-value {
  font-size: 26rpx;
  color: #ffffff;
}

.source-description {
  font-size: 26rpx;
  color: #ffffff;
  line-height: 1.6;
}

.source-rate {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.source-rate-red {
  color: #f87171;
}

.source-rate-green {
  color: #4ade80;
}

.info-card {
  padding: 0;
  overflow: hidden;
  margin-top: 20rpx;
}

.card-title {
  background: rgba(59, 130, 246, 0.12);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #e2e8f0;
  text-align: center;
}

.info-table {
  width: 100%;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.table-row:last-child {
  border-bottom: none;
}

.table-cell-left {
  width: 40%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  background: #000000;
}

.table-cell-right {
  width: 60%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #1e293b;
}

.table-cell-right text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.polarity-icon {
  width: 32rpx;
  height: 32rpx;
}

.polarity-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.polarity-item:last-child {
  margin-bottom: 0;
}

.detail-card {
  padding: 0;
  overflow: hidden;
  margin-top: 20rpx;
}

.attack-table {
  width: 100%;
}

.attack-row {
  display: flex;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.attack-row:last-child {
  border-bottom: none;
}

.attack-cell-left {
  width: 40%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 700;
  background: #000000;
}

.attack-cell-right {
  width: 60%;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
  background: #1e293b;
}

.forging-card {
  padding: 0;
  overflow: hidden;
  margin-top: 20rpx;
}

.forging-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.forging-materials {
  display: flex;
  justify-content: space-around;
  flex: 1;
}

.forging-material {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.material-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.material-content.material-empty {
  justify-content: center;
  height: 100%;
}

.material-icon {
  width: 60rpx;
  height: 60rpx;
}

.material-amount {
  font-size: 22rpx;
  color: #ffffff;
  text-align: center;
}

.material-na {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
}

.forging-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 20rpx;
}

.forging-time {
  font-size: 24rpx;
  color: #ffffff;
}

.forging-speed {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.speed-icon {
  width: 24rpx;
  height: 24rpx;
}

.forging-price-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.3);
}

.forging-price-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.price-icon {
  width: 24rpx;
  height: 24rpx;
}