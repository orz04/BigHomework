<view class="container">
  <view wx:if="{{missing}}" class="empty panel">未找到战甲信息</view>

  <view wx:else class="detail">
    <view class="page-title centered-title">{{tenno.title}}</view>

    <view class="image-card panel">
      <image class="tenno-detail-image" src="{{tenno.image}}" mode="aspectFit"></image>
    </view>

    <view class="info-card panel">
      <view class="section-title">基础信息</view>
      <view class="basic-table">
        <block wx:for="{{tenno.basicInfo}}" wx:key="label">
          <view class="basic-row">
            <view class="basic-cell basic-label">{{item.label}}</view>
            <view class="basic-cell basic-value">
              <image wx:if="{{item.icon}}" class="basic-icon" src="{{item.icon}}" mode="aspectFit"></image>
              <text>{{item.value}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="info-card panel">
      <view class="section-title">锻造需求</view>
      <block wx:for="{{tenno.forging.components}}" wx:key="name">
