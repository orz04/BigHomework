.detail {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-title-center {
  margin-top: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.centered-title {
  text-align: center;
}

.image-card {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.tenno-detail-image {
  width: 360rpx;
  height: 360rpx;
}

.info-card {
  padding: 28rpx;
}

.basic-table {
  margin-top: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 18rpx;
}

.basic-row {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
}

.basic-row:first-child {
  border-top: 0;
}

.basic-cell {
  padding: 18rpx 20rpx;
  color: #cbd5e1;
  font-size: 26rpx;
  line-height: 1.5;
}

.basic-label {
  background: rgba(59, 130, 246, 0.12);
  color: #f8fafc;
  font-weight: 700;
  text-align: center;
}

.basic-value {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-left: 1rpx solid rgba(148, 163, 184, 0.16);
}

.basic-icon {
  width: 36rpx;
  height: 36rpx;
}

.forging-price-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 18rpx;
}

.forging-price-cell {
  display: flex;
  min-height: 88rpx;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border-left: 1rpx solid rgba(148, 163, 184, 0.16);
  color: #cbd5e1;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}

.forging-price-cell:first-child {
  grid-column: span 3;
}

.forging-price-cell:last-child {
  grid-column: span 4;
}

.forging-price-cell:first-child {
  border-left: 0;
}

.price-icon {
  width: 36rpx;
  height: 36rpx;
}

.forging-component-name {
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(59, 130, 246, 0.12);
  border-radius: 12rpx;
  color: #f8fafc;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.forging-row {
  display: flex;
  margin-top: 12rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 18rpx;
  overflow: hidden;
}

.forging-materials {
  display: flex;
  flex: 1;
  padding: 16rpx;
  border-right: 1rpx solid rgba(148, 163, 184, 0.16);
}

.forging-material {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.forging-material.na-material {
  justify-content: center;
  min-height: 72rpx;
}

.material-icon {
  width: 48rpx;
  height: 48rpx;
}

.material-placeholder {
  width: 48rpx;
  height: 48rpx;
  background: rgba(148, 163, 184, 0.1);
  border-radius: 8rpx;
}

.material-amount {
  color: #cbd5e1;
  font-size: 22rpx;
  text-align: center;
}

.forging-info {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 16rpx;
  gap: 8rpx;
}

.forging-time,
.forging-speed {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #cbd5e1;
  font-size: 22rpx;
}

.speed-icon {
  width: 28rpx;
  height: 28rpx;
}

.info-text {
  margin-top: 16rpx;
  color: #cbd5e1;
  font-size: 26rpx;
  line-height: 1.7;
}

.highlight {
  color: #3b82f6;
  font-weight: 600;
}

.info-text.note {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
  color: #94a3b8;
  font-size: 24rpx;
}

.drops-table {
  margin-top: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 18rpx;
  overflow: hidden;
}

.drops-header {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr 1.2fr;
  background: rgba(59, 130, 246, 0.12);
}

.drops-row {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr 1.2fr;
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
}

.drops-cell {
  padding: 14rpx 12rpx;
  color: #cbd5e1;
  font-size: 22rpx;
  line-height: 1.4;
  text-align: center;
}

.drops-header .drops-cell {
  color: #f8fafc;
  font-weight: 600;
  font-size: 24rpx;
}

.empty {
  padding: 40rpx;
  color: #cbd5e1;
  font-size: 28rpx;
  text-align: center;
}
