.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.centered-title {
  text-align: center;
}

.faction-section {
  padding: 24rpx 28rpx;
}

.faction-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.group-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(30, 41, 59, 0.72);
}

.group-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.group-image {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.group-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.detail-btn {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.relation-list {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.16);
}

.relation-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.relation-icon {
  width: 46rpx;
  height: 46rpx;
}

.relation-name,
.relation-standing {
  width: 100%;
  text-align: center;
  font-size: 18rpx;
  line-height: 1.2;
}

.relation-name {
  color: #ffb178;
}

.relation-standing.ally {
  color: #39df72;
}

.relation-standing.opposed {
  color: #ff8a2c;
}

.relation-standing.enemy {
  color: #ff4f6d;
}
