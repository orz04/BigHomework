.detail-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-header,
.detail-section,
.missing-box {
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(17, 24, 39, 0.72);
}

.detail-title,
.section-title,
.missing-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 16rpx;
}

.detail-image {
  width: 100%;
  height: 360rpx;
}

.relation-list {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.relation-item {
  flex: 1;
  text-align: center;
}

.relation-icon {
  width: 64rpx;
  height: 64rpx;
}

.relation-name {
  color: #60a5fa;
  font-size: 20rpx;
}

.relation-standing.ally {
  color: #22c55e;
}

.relation-standing.opposed {
  color: #fb923c;
}

.relation-standing.enemy {
  color: #ef4444;
}

.rank-table {
  display: flex;
  flex-direction: column;
}

.rank-row {
  display: flex;
  border-top: 1rpx solid rgba(148, 163, 184, 0.2);
}

.rank-head {
  font-weight: 700;
  color: #f8fafc;
}

.rank-cell {
  flex: 1;
  padding: 12rpx 6rpx;
  font-size: 18rpx;
  color: #e2e8f0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  overflow: hidden;
}

.rank-tribute-header {
  flex: 2.8;
}

.rank-col-level {
  flex: 0.6;
}

.rank-col-title {
  flex: 1;
}

.rank-col-tribute {
  flex: 1.5;
}

.rank-col-credit {
  flex: 1.3;
}

.rank-col-reward {
  flex: 1.6;
}

.rank-col-standing {
  flex: 1.2;
}

.rank-tribute,
.rank-credit {
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
}

.tribute-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  width: 100%;
  padding: 2rpx 0;
}

.tribute-count {
  font-size: 18rpx;
  color: #94a3b8;
  line-height: 1.2;
}

.tribute-name {
  width: 100%;
  text-align: center;
  font-size: 18rpx;
  color: #cbd5f5;
  line-height: 1.2;
  word-break: break-word;
}

.rank-tribute-content,
.rank-credit-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  flex-wrap: wrap;
  max-width: 100%;
}

.rank-item-icon {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.rank-credit .rank-item-icon {
  width: 36rpx;
  height: 36rpx;
}

.rank-icon-placeholder {
  min-width: 56rpx;
  height: 56rpx;
  padding: 0 10rpx;
  border: 1rpx dashed rgba(96, 165, 250, 0.9);
  border-radius: 12rpx;
  color: #60a5fa;
  font-size: 18rpx;
  line-height: 56rpx;
  text-align: center;
  flex-shrink: 0;
}

.tribute-icon-small {
  width: 44rpx;
  height: 44rpx;
  min-width: 44rpx;
  line-height: 44rpx;
  font-size: 14rpx;
  padding: 0;
}

.intro-paragraph {
  font-size: 24rpx;
  line-height: 1.7;
  color: #cbd5f5;
  margin-top: 12rpx;
}

.intro-paragraph:first-child {
  margin-top: 0;
}

.intro-quote {
  padding: 16rpx 20rpx;
  border-left: 4rpx solid #60a5fa;
  background: rgba(96, 165, 250, 0.08);
  border-radius: 0 12rpx 12rpx 0;
  font-style: italic;
  color: #e0e7ff;
}

.intro-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.intro-list:first-child {
  margin-top: 0;
}

.intro-list-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.intro-list-bullet {
  color: #60a5fa;
  font-size: 26rpx;
  line-height: 1.7;
  flex-shrink: 0;
}

.intro-list-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #cbd5f5;
}

.rank-standing-cost {
  margin-top: 8rpx;
  color: #facc15;
  font-size: 18rpx;
}

.rank-standing-icon {
  width: 36rpx;
  height: 36rpx;
}

.neutral-indicator {
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(96, 165, 250, 0.12);
  color: #93c5fd;
  font-size: 26rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.aux-table {
  display: flex;
  flex-direction: column;
  border-radius: 12rpx;
  overflow: hidden;
}

.aux-row {
  display: flex;
  border-top: 1rpx solid rgba(148, 163, 184, 0.2);
}

.aux-row.aux-head {
  background: rgba(96, 165, 250, 0.18);
  border-top: 0;
  font-weight: 700;
  color: #f8fafc;
}

.aux-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 22rpx;
  color: #e2e8f0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
}

.aux-cell:last-child {
  color: #facc15;
  font-weight: 600;
}
