.detail-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-header,
.detail-section,
.missing-box {
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(17, 24, 39, 0.72);
}

.detail-title,
.section-title,
.missing-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 16rpx;
}

.detail-image {
  width: 100%;
  height: 360rpx;
}

.relation-list {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.relation-item {
  flex: 1;
  text-align: center;
}

.relation-icon {
  width: 64rpx;
  height: 64rpx;
}

.relation-name {
  color: #60a5fa;
  font-size: 20rpx;
}

.relation-standing.ally {
  color: #22c55e;
}

.relation-standing.opposed {
  color: #fb923c;
}

.relation-standing.enemy {
  color: #ef4444;
}

.rank-table {
  display: flex;
  flex-direction: column;
}

.rank-row {
  display: flex;
  border-top: 1rpx solid rgba(148, 163, 184, 0.2);
}

.rank-head {
  font-weight: 700;
  color: #f8fafc;
}

.rank-tribute-header {
  flex: 2;
}

.rank-cell {
  flex: 1;
  padding: 16rpx 10rpx;
  font-size: 20rpx;
  color: #e2e8f0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-tribute,
.rank-credit {
  min-width: 0;
}

.rank-tribute-content,
.rank-credit-content {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.rank-item-icon {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.rank-icon-placeholder {
  min-width: 56rpx;
  height: 56rpx;
  padding: 0 10rpx;
  border: 1rpx dashed rgba(96, 165, 250, 0.9);
  border-radius: 12rpx;
  color: #60a5fa;
  font-size: 18rpx;
  line-height: 56rpx;
  text-align: center;
  flex-shrink: 0;
}
