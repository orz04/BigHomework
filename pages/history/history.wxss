.history-page {
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #f8fafc;
}

.page-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 0 4rpx 16rpx;
}

.toolbar-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.toolbar-action {
  font-size: 24rpx;
  color: #fca5a5;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(127, 29, 29, 0.18);
  border: 1rpx solid rgba(252, 165, 165, 0.28);
}

.toolbar-action--disabled {
  opacity: 0.4;
  color: #94a3b8;
  background: rgba(30, 41, 59, 0.6);
  border-color: rgba(148, 163, 184, 0.18);
}

.empty-card {
  padding: 56rpx 32rpx;
  text-align: center;
  border-radius: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.empty-action {
  display: inline-block;
  margin-top: 28rpx;
  padding: 14rpx 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f4c96b 0%, #c7921c 100%);
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
}

.group-block {
  margin-top: 18rpx;
}

.group-block:first-child {
  margin-top: 0;
}

.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx 14rpx;
}

.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #f4c96b;
  letter-spacing: 1rpx;
}

.group-count {
  font-size: 22rpx;
  color: #64748b;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.entry-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.78);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
}

.entry-item__main {
  flex: 1;
  min-width: 0;
}

.entry-item__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-item__meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 22rpx;
  color: #64748b;
}

.entry-item__tag {
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(244, 201, 107, 0.16);
  color: #f4c96b;
  font-size: 20rpx;
}

.entry-item__time {
  color: #64748b;
}

.entry-item__remove {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 14rpx;
  background: rgba(127, 29, 29, 0.18);
  border: 1rpx solid rgba(252, 165, 165, 0.28);
  color: #fca5a5;
  font-size: 22rpx;
}
