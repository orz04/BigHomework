.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.grid-item {
  padding: 24rpx;
}

.grid-image {
  width: 100%;
  height: 160rpx;
}

.grid-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #d0d0d0;
  text-align: center;
}

.expand-row {
  padding: 24rpx;
  margin-top: 20rpx;
}

.expand-row-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.expand-row-title {
  font-size: 30rpx;
  color: #fff;
}

.expand-row-icon {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.expand-row-body {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.placeholder {
  color: rgba(255, 255, 255, 0.6);
  font-size: 26rpx;
}
