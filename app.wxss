page {
  min-height: 100%;
  background: linear-gradient(180deg, #08101d 0%, #050b16 100%);
  color: #f8fafc;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 32rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #f4c96b;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.section {
  margin-top: 32rpx;
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #e2e8f0;
}

.panel {
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 24rpx;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.2);
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #f8fafc;
}

.page-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(30, 41, 59, 0.95);
  color: #cbd5e1;
  font-size: 22rpx;
}

.form-card {
  padding: 28rpx;
}

.result-value {
  margin-top: 12rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #f4c96b;
}
